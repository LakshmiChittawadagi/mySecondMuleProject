	<flow name="demoprojectFlow2" doc:id="e02dc0a1-9e4c-4808-bc4a-ac2e0c6d3491" >
		<db:select doc:name="Select" doc:id="b78847cf-9c3a-4917-ab8f-d51b3c089610" config-ref="Database_Config" >
			<db:sql ><![CDATA[SELECT * FROM patient;]]></db:sql>
			<db:input-parameters ><![CDATA[#[%dw 2.0
output application/json
---
{
    pageSize: (attributes.queryParams.size default 5) as Number,
    
    // This logic ensures:
    // Page 1 -> (1-1) * 5 = 0 (Starts at record 1)
    // Page 2 -> (2-1) * 5 = 5 (Starts at record 6)
    offset: ((attributes.queryParams.page default 1 as Number) - 1) * (attributes.queryParams.size default 5 as Number)
}]]]></db:input-parameters>
		</db:select>
		<ee:transform doc:name="Transform Message" doc:id="a987fa81-3636-4fca-a3de-c087f0e1ab57" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload
]]></ee:set-payload>
			</ee:message>
		</ee:transform>
		<choice doc:name="Choice" doc:id="c9ed870f-c7ad-40bd-a816-80e5b6e9c91f" >
			<when expression="#[sizeOf(payload) &gt; 0]">
				<ee:transform doc:name="Transform Message" doc:id="5240b110-34d6-4a00-85e7-c3c7d039505c" >
					<ee:message >
						<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
					</ee:message>
				</ee:transform>
			</when>
			<otherwise >
				<set-variable value="#[404]" doc:name="Set Variable" doc:id="49a622bc-879d-44cd-b581-890e3ebf7995" variableName="httpStatus"/>
				<set-payload value='#["Not found"]' doc:name="Set Payload" doc:id="54e6a867-a4b4-4763-9bb6-956762e52d03" />
			</otherwise>
		</choice>
		<error-handler ref="globalError_Handler" />
	</flow>
