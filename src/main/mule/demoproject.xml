	<flow name="demoprojectFlow1" doc:id="afa7ff42-4818-43db-8a80-6cda8bdc8d27" >
		<scheduler doc:name="Scheduler_timer" doc:id="f4e6dd5e-618e-4617-bf4b-84dc0062fb1b" >
			<scheduling-strategy >
				<fixed-frequency frequency="10" timeUnit="SECONDS" />
			</scheduling-strategy>
		</scheduler>
		<logger level="INFO" doc:name="Logger" doc:id="208fe9c0-cfaa-4bd4-94e0-af8ff66ce78b" message="----------------------scheduler time------------------" />
		<set-payload value='#[[1,2,3,"a",4,"b",5, "c",6]]' doc:name='[1,2,3,"a",4,"b",5]' doc:id="849f9289-ea44-4e5b-aeaa-c2fdac9cc5f6" />
		<batch:job jobName="demoprojectBatch_Job" doc:id="aca4178e-85c0-4f30-b6c4-4d53f0195765" maxFailedRecords="10">
			<batch:process-records >
				<batch:step name="Batch_Step" doc:id="f3009d90-5ba7-406e-b839-0dce24afd41f" acceptPolicy="ALL">
					<set-payload value="#[payload * 10]" doc:name="payload*10" doc:id="72b43a16-37de-4c14-817c-2a1290f8c1f3" />
					<batch:aggregator doc:name="Batch Aggregator" doc:id="a9f417a4-25fe-48f9-a704-843bf44f588d" size="2">
						<logger level="INFO" doc:name="Logger" doc:id="78bc7592-dd90-45b5-973f-c472126a5d65" message='#[payload]'/>
					</batch:aggregator>
				</batch:step>
				<batch:step name="Batch_Step1" doc:id="458b6914-d737-4297-9f6c-fb00080ff8d0" acceptPolicy="ALL">
					<batch:aggregator doc:name="Batch Aggregator" doc:id="f179d745-2e47-4afd-a2ff-049e20979789" size="2">
						<logger level="INFO" doc:name="Logger" doc:id="2029133d-c754-41f0-9796-b4bbb5a87f0e" message="#[payload]"/>
					</batch:aggregator>
					<!-- [STUDIO:"Logger"]<logger level="INFO" doc:name="Logger" doc:id="bb1f0115-9203-4f33-932e-291ba773bc72" message="#[payload&#93;"/> [STUDIO] -->
					<set-payload value="#[payload * 5]" doc:name="payload * 5" doc:id="544bcf65-3cf4-430e-86d8-8d61bcd42582" />
				</batch:step>
			</batch:process-records>
			<batch:on-complete>
				<logger level="INFO" doc:name="Logger" doc:id="6587acc5-d737-41ad-9702-cb40e2d0c1d1" message="#[vars.batchJobInstance.totalRecords]"/>
				<logger level="INFO" doc:name="Logger" doc:id="c39edd27-7cc4-44ad-b09c-128fe963b01f" message="#[vars.batchJobInstance.successfulRecords]"/>
				<logger level="INFO" doc:name="Logger" doc:id="76fbedcf-7854-44fa-9671-e8a645839713" message="#[vars.batchJobInstance.failedRecords]"/>

    </batch:on-complete>

		</batch:job>
	</flow>
